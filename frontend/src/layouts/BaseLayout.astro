---
import "../styles/global.css";
const { title = "2023级1班 · 毕业纪念册" } = Astro.props;
const basePath = "/2017-class/";
const buildId = new Date().toISOString().replace(/[-:TZ.]/g, "");
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
      (function () {
        try {
          const dir = sessionStorage.getItem("navDirection");
          if (dir) document.documentElement.classList.add(`nav-enter-${dir}`);
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <div id="app">
      <div class="page-transition" id="pageTransition">
        <div class="page-transition-glow"></div>
      </div>
      <header class="topbar">
        <div class="brand">Angela.</div>
        <nav class="nav">
          <a href={`${basePath}`}>Home</a>
          <a href={`${basePath}class/`}>Class</a>
          <a href={`${basePath}timeline/`}>Timeline</a>
          <a href={`${basePath}starfield/`}>Starfield</a>
          <a href={`${basePath}albums/`}>Albums</a>
          <a href={`${basePath}students/`}>Students</a>
          <span class="nav-indicator" id="navIndicator"></span>
        </nav>
        <div class="actions">
          <button class="ghost" id="openAuth">登录 / 注册</button>
          <button class="ghost" id="logoutBtn" style="display: none;">退出登录</button>
          <button class="ghost" id="openNotifications">消息<span class="badge" id="notificationBadge">0</span></button>
          <span class="status" id="status"></span>
        </div>
      </header>
      <nav class="bottom-nav" aria-label="Mobile Navigation">
        <a href={`${basePath}`}>Home</a>
        <a href={`${basePath}class/`}>Class</a>
        <a href={`${basePath}timeline/`}>Timeline</a>
        <a href={`${basePath}starfield/`}>Starfield</a>
        <a href={`${basePath}albums/`}>Albums</a>
        <a href={`${basePath}students/`}>Students</a>
        <span class="bottom-nav-indicator" id="bottomNavIndicator"></span>
      </nav>
      <slot />
    </div>

    <div class="toast-stack" id="toastStack" aria-live="polite"></div>

    <div class="server-gate" id="serverGate" aria-hidden="true">
      <div class="server-gate-card">
        <div class="server-gate-title">正在唤醒服务器…</div>
        <p>Render 冷启动可能需要 20-60 秒，请稍等。</p>
        <div class="server-gate-status" id="serverGateStatus">正在连接后端…</div>
        <div class="server-gate-dots">
          <span></span><span></span><span></span>
        </div>
      </div>
    </div>

    <button class="fab" id="openProfile">资料/关系</button>
    <div class="drawer-overlay" id="closeProfile"></div>

    <div class="modal" id="authModal" aria-hidden="true">
      <div class="modal-overlay" id="closeAuth"></div>
      <div class="modal-content">
        <h3>登录 / 注册</h3>
        <div class="form-grid">
          <label>姓名（注册用）</label>
          <input id="registerName" type="text" placeholder="真实姓名" />

          <label>一次性邀请码</label>
          <input id="registerInvite" type="text" placeholder="管理员发放的邀请码" />

          <button id="registerBtn">注册并获取Token</button>
        </div>
        <div class="form-grid">
          <label>Token（登录用）</label>
          <input id="loginToken" type="text" placeholder="输入你的Token" />
          <button id="loginBtn">登录</button>
        </div>
        <div class="hint" id="tokenHint"></div>
      </div>
    </div>

    <div class="modal" id="notificationModal" aria-hidden="true">
      <div class="modal-overlay" id="closeNotifications"></div>
      <div class="modal-content">
        <h3>我的消息</h3>
        <div class="notification-list" id="notificationList"></div>
      </div>
    </div>

    <div class="lightbox" id="lightbox" aria-hidden="true">
      <div class="lightbox-overlay" id="lightboxClose"></div>
      <div class="lightbox-content">
        <button class="lightbox-btn" id="lightboxPrev">‹</button>
        <img id="lightboxImage" alt="album" />
        <button class="lightbox-btn" id="lightboxNext">›</button>
        <div class="lightbox-meta" id="lightboxMeta"></div>
      </div>
    </div>

    <script type="module" src={`${basePath}scripts/app.js?v=${buildId}`}></script>
  </body>
</html>
